# =====================================================
# Niyodaya website — git exclusions
# =====================================================

# ---- Dependencies ----
node_modules/

# ---- SvelteKit build / cache ----
/build/
/.svelte-kit/
/package/
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# ---- Environment & secrets ----
.env
.env.*
!.env.example

# ---- OS metadata ----
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
Icon?
._*

# ---- Editors & IDEs ----
.vscode/
!.vscode/extensions.json
.idea/
*.sublime-workspace
*.sublime-project
*.swp
*.swo
*~

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ---- Runtime artefacts ----
/tmp/
/.cache/
/coverage/
niyodaya.log
.niyodaya.pid

# ---- Deployment packages ----
/dist/

# ---- Personal test files ----
*.local
scratch.*
