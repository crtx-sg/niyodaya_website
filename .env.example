# =====================================================
# Niyodaya Foundation - environment variables
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.
# =====================================================

# ---- Insforge backend (data + storage + auth) ----
INSFORGE_URL=https://your-project.insforge.io
INSFORGE_API_KEY=sk_insforge_xxxxxxxxxxxxxxxxxxxx
INSFORGE_ANON_KEY=anon_xxxxxxxxxxxxxxxxxxxx

# =====================================================
# ---- Razorpay payment gateway -----------------------
# Sign up at https://razorpay.com → Merchant account for Niyodaya Foundation.
# Generate TEST keys first (rzp_test_…), flip to LIVE keys after go-live.
# =====================================================

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Public key must be the SAME as RAZORPAY_KEY_ID — it is loaded by the browser
# so Razorpay Checkout can open. Key *secret* is never exposed to the browser.
PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx

# =====================================================
# ---- Email (transactional)  -------------------------
# Two options — SMTP (recommended, works with any email provider) OR
# Resend HTTP API. Set ONE of the two below. SMTP wins if both are set.
# If neither is set, emails are printed to the terminal (dev fallback).
# =====================================================

# --- Option A: SMTP (Gmail / Google Workspace / Zoho / Outlook / your host) ---
# Example for Gmail / Google Workspace:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false        # true only if you use port 465
#   SMTP_USER=contact@niyodaya.in
#   SMTP_PASS=<app password from https://myaccount.google.com/apppasswords>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# --- Option B: Resend HTTP API (https://resend.com) ---
# RESEND_API_KEY=re_xxxxxxxxxxxx

# The From address shown to recipients. Must be on a domain you've verified
# with your email provider (or your SMTP server).
EMAIL_FROM="Niyodaya Foundation <contact@niyodaya.in>"

# Admin inbox that receives a COPY of every form submission & donation.
EMAIL_ADMIN=contact@niyodaya.in

# =====================================================
# ---- Admin access (v0.2) ----------------------------
# Shared password that admin users type on /admin/login.
# The email field is checked against the ADMIN_EMAILS
# allow-list. Cookie is signed with ADMIN_SESSION_SECRET.
#
# LEAVE ADMIN_PASSWORD BLANK to skip auth entirely for
# local dev — the admin pages then run open.
# =====================================================
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=change-me-to-a-long-random-string
ADMIN_EMAILS=contact@niyodaya.in,ganesh@niyodaya.in

# ---- Site URL (used to build links in emails / webhooks) ----
PUBLIC_SITE_URL=https://niyodaya.in
