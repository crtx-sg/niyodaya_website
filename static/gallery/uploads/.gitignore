# =====================================================
# static/gallery/uploads  —  admin-uploaded photos
# =====================================================
# These files are user-generated content uploaded at
# runtime via /admin/gallery. They may contain personal
# photographs of minors whose consent is tracked
# separately (see the consent_ok column on gallery_photos).
#
# NEVER COMMIT anything in this directory to git.
#
# In production, uploads go to Insforge Storage instead
# of this folder. This folder only exists for local dev.
# =====================================================

# Ignore everything in this directory …
*

# … except this .gitignore itself, so the empty folder
# is still checked in and the upload code finds the path.
!.gitignore
